[sub_resource type="GDScript" id="GDScript_24gqh"]
resource_name = "PLR-CameraControl"
script/source = "extends SpringArm3D; class_name PLR_Cam


var player :Player
var rest_pos := Vector3(0,1.5,0)

var inner_dist


func _ready() -> void:
	player = get_parent()
	add_excluded_object(player.get_rid())


func _input(event: InputEvent) -> void:
	if (Input.is_action_just_pressed(\"mouse_lock\")):
		Input.mouse_mode = Input.MOUSE_MODE_CAPTURED if \\
			Input.mouse_mode != Input.MOUSE_MODE_CAPTURED else Input.MOUSE_MODE_VISIBLE
	
	if (Input.mouse_mode == Input.MOUSE_MODE_CAPTURED):
		if event is InputEventMouseMotion:
			var sens = -event.relative*PlayerSettings.uSettings.sensitivity
			player.rot = deg_to_rad(sens.x)
			player.basis = player.basis.rotated(player.up_direction, player.rot)
			rotation_degrees.x += sens.y
			rotation_degrees.x = clamp(rotation_degrees.x, -85, 85)


func _physics_process(delta: float) -> void:
	return
	var input = player.player_inputs[\"input\"]
	var tpos = Vector3(input.x, 0, input.y*.25).normalized()*delta
	position += tpos*5
	position = position.limit_length(1)
"

